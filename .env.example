OPENAI_API_KEY=your_openai_api_key_here
LLAMA_PARSE_API_KEY=your_llamaparse_api_key_here
OPENAI_MODEL=o1-preview
OPENAI_EMBED_MODEL=text-embedding-3-large

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_supabase_publishable_key

SUPABASE_DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres?sslmode=require
SUPABASE_DB_HOST=db.your-project-ref.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_supabase_db_password
SUPABASE_DB_SSLMODE=require
SUPABASE_POOL_MIN_SIZE=1
SUPABASE_POOL_MAX_SIZE=10
SUPABASE_CONNECT_TIMEOUT_SECONDS=10
SUPABASE_RETRY_ATTEMPTS=3

BOLT_DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
BOLT_DB_HOST=
BOLT_DB_PORT=5432
BOLT_DB_NAME=vict
BOLT_DB_USER=
BOLT_DB_PASSWORD=
BOLT_DB_SSLMODE=require
BOLT_POOL_MIN_SIZE=1
BOLT_POOL_MAX_SIZE=10
BOLT_CONNECT_TIMEOUT_SECONDS=10
BOLT_RETRY_ATTEMPTS=3

API_AUTH_ENABLED=false
API_KEYS_CSV=
API_RATE_LIMIT_PER_MINUTE=120
API_RATE_LIMIT_WINDOW_SECONDS=60
ALLOW_START_WITHOUT_DB=false

CHROMA_PATH=./data/chroma
CHROMA_COLLECTION_PREFIX=ekg_notes
CHROMA_NAMESPACE=default
CHROMA_ISOLATE_BY_WEEK=true
UPLOAD_PATH=./data/uploads

# Legacy SQLite source path used only by migration script
AUDIT_DB_PATH=./data/audit.db
TOP_K=6
